{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BeforePaste",
  "version": "0.1.2",
  "identifier": "com.beforewire.beforepaste",
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  },
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BeforePaste Preferences",
        "width": 820,
        "height": 680,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "publisher": "BeforeWire",
    "homepage": "https://beforepaste.com",
    "shortDescription": "Local clipboard protection for AI prompts.",
    "longDescription": "BeforePaste protects AI paste workflows by redacting secrets from clipboard text before it is sent to supported AI apps, websites, and terminals.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2"
        ],
        "section": "utils",
        "priority": "optional"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libayatana-appindicator",
          "librsvg2"
        ],
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
